    {
      "parameters": {
        "operation": "getAll",
        "calendar": { "__rl": true, "value": "primary", "mode": "id" },
        "limit": 10,
        "options": {
          "timeMin": "={{ $now.toISO() }}",
          "timeMax": "={{ $now.plus({ days: 7 }).toISO() }}",
          "orderBy": "startTime",
          "singleEvents": true
        }
      },
      "id": "gcal-list-events",
      "name": "List Events",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.3,
      "position": [1200, 464],
      "credentials": {
        "googleCalendarOAuth2Api": { "id": "REPLACE_WITH_YOUR_GCAL_CREDENTIAL_ID", "name": "Google Calendar OAuth2 API" }
      }
    },
    {
      "parameters": {
        "jsCode": "const events = $input.all();\nif (events.length === 0) {\n  return [{ json: { reply: 'You have no upcoming events in the next 7 days.' } }];\n}\nconst lines = [];\nfor (const item of events) {\n  const e = item.json;\n  const start = e.start?.dateTime || e.start?.date || '';\n  let label = '';\n  if (start.includes('T')) {\n    const d = new Date(start);\n    label = d.toLocaleString('en-US', { weekday: 'short', month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });\n  } else if (start) {\n    label = new Date(start + 'T00:00:00').toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });\n  }\n  lines.push(`• ${e.summary || 'Untitled'}${label ? ' — ' + label : ''}`);\n}\nreturn [{ json: { reply: `Here are your upcoming events:\\n${lines.join('\\n')}` } }];"
      },
      "id": "gcal-format-list",
      "name": "Format List Reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1440, 464]
    },
    {
      "parameters": {
        "resource": "chat",
        "chatModel": "gpt-4o-mini",
        "prompt": {
          "messages": [
            {
              "role": "system",
              "content": "=Extract calendar event details from the user's message as a JSON object with these exact fields:\n- summary: event title (required)\n- startDateTime: ISO8601 datetime string (required, infer from context)\n- endDateTime: ISO8601 datetime string (default to startDateTime + 1 hour if not given)\n- location: string or null\n- description: string or null\n- timeZone: timezone string (default 'America/Los_Angeles')\n\nCurrent date and time: {{ $now.toISO() }}.\nReturn ONLY the raw JSON object, no markdown, no code blocks, no explanation."
            },
            { "content": "={{ $json.message }}" }
          ]
        },
        "options": { "maxTokens": 250, "temperature": 0 },
        "requestOptions": {}
      },
      "id": "oai-parse-create",
      "name": "Parse Create Intent",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.1,
      "position": [1200, 288],
      "credentials": {
        "openAiApi": { "id": "REPLACE_WITH_YOUR_OPENAI_CREDENTIAL_ID", "name": "OpenAI account" }
      }
    },
    {
      "parameters": {
        "jsCode": "const aiContent = $input.first().json.message.content;\nlet d;\ntry { d = JSON.parse(aiContent); }\ncatch { const m = aiContent.match(/\\{[\\s\\S]*\\}/); d = JSON.parse(m[0]); }\nreturn [{ json: {\n  summary: d.summary || 'New Event',\n  start: d.startDateTime,\n  end: d.endDateTime || null,\n  location: d.location || '',\n  description: d.description || '',\n  timeZone: d.timeZone || 'America/Los_Angeles'\n} }];"
      },
      "id": "code-build-event",
      "name": "Build Event",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1440, 288]
    },
    {
      "parameters": {
        "calendar": { "__rl": true, "value": "primary", "mode": "id" },
        "start": "={{ $json.start }}",
        "end": "={{ $json.end || $json.start }}",
        "additionalFields": {
          "summary": "={{ $json.summary }}",
          "location": "={{ $json.location }}",
          "description": "={{ $json.description }}"
        }
      },
      "id": "gcal-create-event",
      "name": "Create Calendar Event",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.3,
      "position": [1680, 288],
      "credentials": {
        "googleCalendarOAuth2Api": { "id": "REPLACE_WITH_YOUR_GCAL_CREDENTIAL_ID", "name": "Google Calendar OAuth2 API" }
      }
    },
    {
      "parameters": {
        "jsCode": "const event = $input.first().json;\nconst title = event.summary || 'Event';\nconst startStr = event.start?.dateTime || event.start?.date || '';\nlet label = '';\nif (startStr.includes('T')) {\n  label = new Date(startStr).toLocaleString('en-US', { weekday: 'short', month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });\n} else if (startStr) {\n  label = new Date(startStr + 'T00:00:00').toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });\n}\nreturn [{ json: { reply: `Created: \"${title}\"${label ? ' on ' + label : ''}` } }];"
      },
      "id": "code-format-create",
      "name": "Format Create Reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1920, 288]
    },
    {
      "parameters": {
        "resource": "chat",
        "chatModel": "gpt-4o-mini",
        "prompt": {
          "messages": [
            {
              "role": "system",
              "content": "=Extract calendar update intent as a JSON object:\n- eventQuery: keywords to identify the event (required)\n- dateHint: approximate date ISO8601 or null\n- changes: object with only the fields to change (may include: summary, startDateTime, endDateTime, location, description)\n\nCurrent date: {{ $now.toFormat('yyyy-MM-dd') }}. Return ONLY raw JSON."
            },
            { "content": "={{ $json.message }}" }
          ]
        },
        "options": { "maxTokens": 200, "temperature": 0 },
        "requestOptions": {}
      },
      "id": "oai-parse-update",
      "name": "Parse Update Intent",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.1,
      "position": [1200, 640],
      "credentials": {
        "openAiApi": { "id": "REPLACE_WITH_YOUR_OPENAI_CREDENTIAL_ID", "name": "OpenAI account" }
      }
    },
    {
      "parameters": {
        "operation": "getAll",
        "calendar": { "__rl": true, "value": "primary", "mode": "id" },
        "limit": 20,
        "options": {
          "timeMin": "={{ $now.toISO() }}",
          "timeMax": "={{ $now.plus({ days: 14 }).toISO() }}",
          "orderBy": "startTime",
          "singleEvents": true
        }
      },
      "id": "gcal-search-update",
      "name": "Search Events for Update",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.3,
      "position": [1440, 640],
      "credentials": {
        "googleCalendarOAuth2Api": { "id": "REPLACE_WITH_YOUR_GCAL_CREDENTIAL_ID", "name": "Google Calendar OAuth2 API" }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $('Parse Update Intent').first().json.message.content;\nlet intent;\ntry { intent = JSON.parse(raw); } catch { intent = JSON.parse(raw.match(/\\{[\\s\\S]*\\}/)[0]); }\nconst events = $input.all().map(i => i.json);\nconst q = (intent.eventQuery || '').toLowerCase();\nconst match = events.find(e => (e.summary || '').toLowerCase().includes(q));\nif (!match) {\n  return [{ json: { notFound: true, query: intent.eventQuery || 'event', eventId: 'not-found' } }];\n}\nconst ch = intent.changes || {};\nconst body = {};\nif (ch.summary) body.summary = ch.summary;\nif (ch.startDateTime) body.start = { dateTime: ch.startDateTime, timeZone: 'America/Los_Angeles' };\nif (ch.endDateTime) body.end = { dateTime: ch.endDateTime, timeZone: 'America/Los_Angeles' };\nif (ch.location) body.location = ch.location;\nif (ch.description) body.description = ch.description;\nreturn [{ json: { notFound: false, eventId: match.id, originalSummary: match.summary, patchBody: body } }];"
      },
      "id": "code-find-update",
      "name": "Find and Prepare Update",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1680, 640]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ 'https://www.googleapis.com/calendar/v3/calendars/10zinsteel%40gmail.com/events/' + $json.eventId }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleCalendarOAuth2Api",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify($json.patchBody) }}",
        "options": {}
      },
      "id": "gcal-update-event",
      "name": "Update Calendar Event",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1920, 640],
      "credentials": {
        "googleCalendarOAuth2Api": { "id": "REPLACE_WITH_YOUR_GCAL_CREDENTIAL_ID", "name": "Google Calendar OAuth2 API" }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const prep = $('Find and Prepare Update').first().json;\nif (prep.notFound) {\n  return [{ json: { reply: `I couldn't find an event matching \"${prep.query}\" in your upcoming calendar.` } }];\n}\nconst result = $input.first().json;\nif (result.error || !result.id) {\n  return [{ json: { reply: `Found \"${prep.originalSummary}\" but couldn't update it. Please try again.` } }];\n}\nreturn [{ json: { reply: `Updated \"${result.summary || prep.originalSummary}\" successfully!` } }];"
      },
