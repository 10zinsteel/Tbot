        "chatModel": "gpt-4o-mini",
        "prompt": {
          "messages": [
            {
              "role": "system",
              "content": "Classify the user message into exactly one of: general_chat, calendar_create, calendar_list, calendar_update, calendar_delete, unknown. Reply with only the label, no punctuation, no explanation."
            },
