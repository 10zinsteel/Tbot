        "options": { "maxTokens": 20, "temperature": 0 },
        "requestOptions": {}
      },
      "id": "node-classify",
      "name": "Classify Intent",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.1,
      "position": [480, 304],
      "credentials": {
        "openAiApi": { "id": "REPLACE_WITH_YOUR_OPENAI_CREDENTIAL_ID", "name": "OpenAI account" }
      }
    },
    {
      "parameters": {
        "jsCode": "const intent = $input.first().json.message.content.trim().toLowerCase();\nconst message = $('Receive from TBot').first().json.body.message;\nreturn [{ json: { intent, message } }];"
      },
      "id": "node-extract",
      "name": "Extract Intent",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 304]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": { "conditions": [{ "leftValue": "={{ $json.intent }}", "rightValue": "general_chat", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" },
              "renameOutput": true, "outputKey": "general_chat"
            },
            {
              "conditions": { "conditions": [{ "leftValue": "={{ $json.intent }}", "rightValue": "calendar_create", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" },
              "renameOutput": true, "outputKey": "calendar_create"
            },
            {
              "conditions": { "conditions": [{ "leftValue": "={{ $json.intent }}", "rightValue": "calendar_list", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" },
              "renameOutput": true, "outputKey": "calendar_list"
            },
            {
              "conditions": { "conditions": [{ "leftValue": "={{ $json.intent }}", "rightValue": "calendar_update", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" },
              "renameOutput": true, "outputKey": "calendar_update"
            },
            {
              "conditions": { "conditions": [{ "leftValue": "={{ $json.intent }}", "rightValue": "calendar_delete", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" },
              "renameOutput": true, "outputKey": "calendar_delete"
            }
          ]
        },
        "options": { "fallbackOutput": "extra" }
      },
